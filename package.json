{
  "name": "volunteer-registration-system",
  "version": "1.0.0",
  "description": "Volunteer Registration and Management System",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend --legacy-peer-deps",
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npm run start --prefix backend",
    "client": "npm run dev --prefix frontend"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
